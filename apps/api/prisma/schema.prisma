// Webduct ordering platform — data model.
// Mirrors the entity/enum structure reverse-engineered from the original
// Buildcentrix ordering-ui (submit-order wizard, manage-product, cart).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums (kept in sync with libs/shared/src/enums.ts)
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  CREW
  ADMIN
}

enum ProductType {
  SIMPLE
  WITH_ATTRIBUTES
}

enum ProductOverrideType {
  NONE
  PRICE
  WEIGHT
  PRICE_AND_WEIGHT
}

enum CustomInputFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  MULTISELECT
  BOOLEAN
}

enum ShippingOption {
  STANDARD
  PICKUP
  DELIVERY
  FREIGHT
  WILL_CALL
}

enum NotificationType {
  EMAIL
  USER
  CREW
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_PRODUCTION
  SHIPPED
  COMPLETED
  CANCELLED
}

enum CartStatus {
  ACTIVE
  CONVERTED
}

// ---------------------------------------------------------------------------
// People / org
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique @db.VarChar(255)
  passwordHash String
  name         String
  role         UserRole   @default(USER)
  active       Boolean    @default(true)
  userGroup    UserGroup? @relation(fields: [userGroupId], references: [id])
  userGroupId  String?
  crews        Crew[]     @relation("CrewMembers")

  ownedJobs        Job[]          @relation("JobOwner")
  carts            Cart[]
  ordersCreated    Order[]        @relation("OrderCreatedBy")
  measuredOrders   Order[]        @relation("OrderMeasuredBy")
  orderedForOrders Order[]        @relation("OrderOrderedFor")
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserGroup {
  id     String  @id @default(cuid())
  name   String
  users  User[]
  orders Order[]
}

model Crew {
  id            String         @id @default(cuid())
  name          String
  members       User[]         @relation("CrewMembers")
  notifications Notification[]
}

// ---------------------------------------------------------------------------
// Jobs / addresses
// ---------------------------------------------------------------------------

model Address {
  id           String     @id @default(cuid())
  name         String?
  line1        String
  line2        String?
  city         String
  region       String
  postal       String
  country      String     @default("US")
  phone        String?
  instructions String?
  jobs         Job[]
  shipments    Shipment[]
}

model Job {
  id        String   @id @default(cuid())
  name      String
  number    String
  phase     String?
  address   Address? @relation(fields: [addressId], references: [id])
  addressId String?
  owner     User?    @relation("JobOwner", fields: [ownerId], references: [id])
  ownerId   String?
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Catalog / products
// ---------------------------------------------------------------------------

model Catalog {
  id          String     @id @default(cuid())
  name        String
  description String?
  active      Boolean    @default(true)
  categories  Category[]
  products    Product[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  parentId  String?
  children  Category[] @relation("CategoryTree")
  catalog   Catalog    @relation(fields: [catalogId], references: [id])
  catalogId String
  products  Product[]
}

model Product {
  id           String              @id @default(cuid())
  sku          String              @unique
  name         String
  description  String?
  type         ProductType         @default(SIMPLE)
  installable  Boolean             @default(false)
  overrideType ProductOverrideType @default(NONE)
  basePrice    Decimal             @db.Decimal(12, 2)
  weight       Decimal             @db.Decimal(12, 3)
  unit         String              @default("EA")
  active       Boolean             @default(true)

  catalog    Catalog   @relation(fields: [catalogId], references: [id])
  catalogId  String
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  images           ProductImage[]
  attributes       ProductAttribute[]
  asset3d          Product3DAsset?
  cartItems        CartItem[]
  orderLines       OrderLine[]
  fulfillmentLinks FulfillmentGroupProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductAttribute {
  id        String               @id @default(cuid())
  name      String
  type      CustomInputFieldType @default(TEXT)
  required  Boolean              @default(false)
  options   String[]
  sortOrder Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model Product3DAsset {
  id           String  @id @default(cuid())
  gltfUrl      String?
  thumbnailUrl String?
  // Procedural duct geometry parameters when there is no glTF asset.
  meta         Json?
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String  @unique
}

model FulfillmentGroup {
  id       String                    @id @default(cuid())
  name     String
  products FulfillmentGroupProduct[]
}

model FulfillmentGroupProduct {
  group     FulfillmentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@id([groupId, productId])
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  order     Order?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id                 String  @id @default(cuid())
  cart               Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId             String
  product            Product @relation(fields: [productId], references: [id])
  productId          String
  qty                Int     @default(1)
  unitPrice          Decimal @db.Decimal(12, 2)
  unitWeight         Decimal @db.Decimal(12, 3)
  selectedAttributes Json    @default("{}")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id     String      @id @default(cuid())
  number String      @unique
  status OrderStatus @default(SUBMITTED)

  createdBy   User   @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdById String

  cart   Cart?   @relation(fields: [cartId], references: [id])
  cartId String? @unique

  job   Job?    @relation(fields: [jobId], references: [id])
  jobId String?

  poNumber     String?
  tag          String?
  measuredBy   User?      @relation("OrderMeasuredBy", fields: [measuredById], references: [id])
  measuredById String?
  orderedFor   User?      @relation("OrderOrderedFor", fields: [orderedForId], references: [id])
  orderedForId String?
  userGroup    UserGroup? @relation(fields: [userGroupId], references: [id])
  userGroupId  String?

  orderedDate   DateTime?
  requestedDate DateTime?

  shippingOption ShippingOption @default(STANDARD)

  instructions String? // sanitized CKEditor HTML

  totalCount  Int     @default(0)
  totalPrice  Decimal @default(0) @db.Decimal(12, 2)
  totalWeight Decimal @default(0) @db.Decimal(12, 3)

  pricingMessage  String?
  deliveryMessage String?

  lines         OrderLine[]
  shipment      Shipment?
  notifications Notification[]
  attachments   Attachment[]
  customValues  CustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderLine {
  id                 String  @id @default(cuid())
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            String
  product            Product @relation(fields: [productId], references: [id])
  productId          String
  qty                Int
  unitPrice          Decimal @db.Decimal(12, 2)
  unitWeight         Decimal @db.Decimal(12, 3)
  lineTotal          Decimal @db.Decimal(12, 2)
  lineWeight         Decimal @db.Decimal(12, 3)
  selectedAttributes Json    @default("{}")
}

model Shipment {
  id                   String         @id @default(cuid())
  order                Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId              String         @unique
  shippingOption       ShippingOption
  windowStart          DateTime?
  windowEnd            DateTime?
  destination          Address?       @relation(fields: [destinationAddressId], references: [id])
  destinationAddressId String?
  status               String         @default("PENDING")
}

model Notification {
  id      String           @id @default(cuid())
  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  type    NotificationType
  email   String?          @db.VarChar(255)
  user    User?            @relation(fields: [userId], references: [id])
  userId  String?
  crew    Crew?            @relation(fields: [crewId], references: [id])
  crewId  String?

  // Prevents duplicate recipients on the same order (email/user/crew uniqueness).
  @@unique([orderId, type, email, userId, crewId])
}

model Attachment {
  id        String   @id @default(cuid())
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId   String?
  filename  String
  url       String
  sizeBytes Int
  mimeType  String
  note      String?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Custom (dynamic) form fields
// ---------------------------------------------------------------------------

model CustomFieldDef {
  id        String               @id @default(cuid())
  scope     String               @default("ORDER")
  label     String
  type      CustomInputFieldType @default(TEXT)
  required  Boolean              @default(false)
  options   String[]
  sortOrder Int                  @default(0)
  values    CustomFieldValue[]
}

model CustomFieldValue {
  id      String         @id @default(cuid())
  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  def     CustomFieldDef @relation(fields: [defId], references: [id])
  defId   String
  value   Json

  @@unique([orderId, defId])
}
